APP_NAME=auto-download-py
APP_HOST=0.0.0.0
APP_PORT=7982
APP_CONTEXT_PATH=/auto-download
LOG_LEVEL=INFO
LOG_FILE=./logs/auto-download-py.log

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auto_download
DB_USER=root
DB_PASSWORD=root
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# PROFILE_DIR must point to the Chrome profile that already has the target extensions installed.
# Close other Chrome processes that use this profile before starting the service.
PROFILE_DIR=C:/cache/chromeTest/auto-download/shared-profile
# Prefer a normally installed Chrome for extension-toolbar UI checks.
# Chrome for Testing may still require manual validation of the extension menu.
BROWSER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
DEBUG_PORT=29222
ONLY_ONE_ACTIVE_SESSION=true
START_URL=about:blank
START_TIMEOUT_MS=15000
CDP_CONNECT_TIMEOUT_MS=15000
BING_URL=https://www.bing.com
HEADLESS=false
SLOW_MO_MS=300
CDP_READY_RETRY_INTERVAL_MS=500
CDP_READY_MAX_WAIT_MS=15000
