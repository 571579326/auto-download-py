APP_NAME=auto-download-py
APP_HOST=0.0.0.0
APP_PORT=7982
APP_CONTEXT_PATH=/auto-download
LOG_LEVEL=INFO
LOG_FILE=./logs/auto-download-py.log

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auto_download
DB_USER=root
DB_PASSWORD=root
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

PROFILE_DIR=C:/chrome_debug_profile
BROWSER_EXECUTABLE_PATH=C:/software/chrome-win64/chrome.exe
DEBUG_PORT=9222
ONLY_ONE_ACTIVE_SESSION=true
START_URL=about:blank
START_TIMEOUT_MS=5000
CDP_CONNECT_TIMEOUT_MS=5000
BING_URL=https://www.bing.com
HEADLESS=false
SLOW_MO_MS=0
CDP_READY_RETRY_INTERVAL_MS=500
CDP_READY_MAX_WAIT_MS=10000
CDP_HTTP_OPEN_TIMEOUT_MS=5000
OPEN_PAGE_MODE=cdp_http

# 纯净模式接口 /browser/session/open-pure 使用。
# 为空时不追加 URL，尽量贴近手动快捷方式：chrome.exe --remote-debugging-port=9222 --user-data-dir=...
PURE_BROWSER_START_URL=
# 默认不追加 --new-window，尽量减少和手动快捷方式的差异。
PURE_BROWSER_NEW_WINDOW=false

# Selenium 附加模式接口 /browser/session/open-selenium 使用。
# 该模式会连接 127.0.0.1:DEBUG_PORT，打开URL后立即断开 driver。
SELENIUM_BROWSER_START_URL=about:blank
SELENIUM_BROWSER_NEW_WINDOW=true
SELENIUM_PAGE_LOAD_TIMEOUT_MS=8000
# false：Selenium 打开 URL 后不读 title/current_url，进一步降低接管强度。
SELENIUM_READ_PAGE_INFO=false
# 离线或 Selenium Manager 自动下载失败时再填写，例如 C:/software/chromedriver-win64/chromedriver.exe
SELENIUM_CHROMEDRIVER_PATH=

# /biz/page-flow 使用的 Playwright 短接管配置。
# 只在打开配置页的一瞬间 connect_over_cdp，打开 URL 后立即断开。
PLAYWRIGHT_ONCE_NEW_WINDOW=true
PLAYWRIGHT_ONCE_CONNECT_TIMEOUT_MS=5000
PLAYWRIGHT_ONCE_NAVIGATION_TIMEOUT_MS=3000
# false：Playwright 打开 URL 后不读 title/url，不等待 DOM/iframe/load。
PLAYWRIGHT_ONCE_READ_PAGE_INFO=false

AUTO_CLICK_SECURITY_CHECK=true
AUTO_CLICK_IMAGE_PATHS=C:/code/py/auto-download-py/app/visual/templates/cf_check_dark.png;C:/code/py/auto-download-py/app/visual/templates/cf_check_white.png
AUTO_CLICK_IMAGE_MATCH_MODE=or
AUTO_CLICK_IMAGE_CONFIDENCE=0.7
AUTO_CLICK_IMAGE_TIMEOUT_MS=30000
AUTO_CLICK_IMAGE_RETRY_INTERVAL_MS=400
# 图像点击偏移：相对匹配到的图片区域左上角。cf_check_* 模板包含文字，默认点击左侧复选框内部。
AUTO_CLICK_IMAGE_CLICK_OFFSET_X=14
AUTO_CLICK_IMAGE_CLICK_OFFSET_Y=13
# 点击前激活浏览器窗口，避免识别到了但点击落不到 Chrome 窗口。
AUTO_CLICK_ACTIVATE_WINDOW_BEFORE=true
AUTO_CLICK_WINDOW_TITLE_REGEX=.*(hxcy|Cloudflare|安全|驗證|验证|Chrome).*
PAGE_STABILIZE_SECONDS=3
